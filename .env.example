# ==========================================
# SQL Query Assistant - Environment Config
# ==========================================

# Main Application Database Connection
# Inside docker-compose, this connects to the postgres container:
DATABASE_URL=postgresql://postgres:postgres@db:5432/sql_assistant
# For local running outside docker, use:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sql_assistant

# Security Secret key for signing JWT tokens (Change this to a strong random hash in production!)
SECRET_KEY=SUPER_SECRET_SECURITY_KEY_FOR_JWT_SIGNING_1234567890

# AI Provider choice: 'gemini' or 'mock'
AI_PROVIDER=gemini

# Google Gemini API key (Required if AI_PROVIDER=gemini)
GEMINI_API_KEY=
